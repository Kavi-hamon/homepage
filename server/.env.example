PORT=8080

# MongoDB with username + password (replace USERNAME / PASSWORD / host as needed):
#
# User created on database "homepage":
#   MONGO_URI=mongodb://USERNAME:PASSWORD@127.0.0.1:27017/homepage?authSource=homepage
#
# User created on "admin" (common for root):
#   MONGO_URI=mongodb://USERNAME:PASSWORD@127.0.0.1:27017/admin?authSource=admin
#
# No auth (local dev only):
#   MONGO_URI=mongodb://127.0.0.1:27017
#
# Password with @ # : etc. → URL-encode (e.g. p@ss → p%40ss)
MONGO_URI=mongodb://USERNAME:PASSWORD@127.0.0.1:27017/homepage?authSource=homepage
MONGO_DB=homepage

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match "Authorized redirect URIs" exactly, e.g.:
OAUTH_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Angular dev server (CORS + return URL allowlist)
FRONTEND_ORIGIN=http://localhost:4200

# Random secret, min 16 chars (use 32+ in production)
JWT_SECRET=change-me-to-a-long-random-string

# Optional cookie name
# SESSION_COOKIE=homepage_session
